# OpenAI 兼容接口（DeepSeek / 通义 / OpenAI / 本地网关均可）
TANGYUAN_API_KEY=sk-xxx
TANGYUAN_BASE_URL=https://api.deepseek.com
TANGYUAN_MODEL=deepseek-chat

# 可选
TANGYUAN_MAX_STEPS=30
TANGYUAN_WORKSPACE=.
# 会话压缩：非 system 消息超过 N 条或总字符超阈值时压缩旧轮次
TANGYUAN_COMPACT_AFTER_MESSAGES=24
TANGYUAN_COMPACT_KEEP_RECENT=10
TANGYUAN_COMPACT_AFTER_CHARS=80000
# 交互确认（-y 时全部关闭）
TANGYUAN_REQUIRE_CONFIRM_SHELL=true
TANGYUAN_CONFIRM_WRITES=true
# GitHub MCP（查仓库/Issue/PR）
# 方式1: gh auth login 后自动可用
# 方式2: 填写 PAT（classic 或 fine-grained，至少 repo + read:org 等按需）
GITHUB_PERSONAL_ACCESS_TOKEN=
